<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/28.2.8 Chrome/140.0.7339.240 Electron/38.4.0 Safari/537.36" version="28.2.8">
  <diagram id="bpmn_data_collection" name="流程示例">
    <mxGraphModel dx="1426" dy="875" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="pool" value="xxxx申请流程示例" style="swimlane;horizontal=1;startSize=40;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=16;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="900" height="1040" as="geometry" />
        </mxCell>
        <mxCell id="lane1" value="申请人" style="swimlane;horizontal=1;startSize=30;fillColor=#ffffff;strokeColor=#000000;fontSize=14;" parent="pool" vertex="1">
          <mxGeometry width="260" height="1040" as="geometry" />
        </mxCell>
        <mxCell id="start" value="开始" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=2;fillColor=#ffffff;strokeColor=#000000;" parent="lane1" vertex="1">
